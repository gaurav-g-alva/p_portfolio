---
import { getCollection } from 'astro:content';
import { siteConfig } from '../config';

let education = [];
try {
  education = await getCollection('education');
} catch (e) {
  // Fallback
}
---

<section class="py-16 border-b border-rule">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
    <!-- Left: Eyebrow and Title -->
    <div>
      <span class="mono-label block mb-2">{siteConfig.educationEyebrow || "04 · credentials"}</span>
      <h2 class="text-2xl font-display font-medium text-ink tracking-tight">{siteConfig.educationTitle || "education & degrees"}</h2>
    </div>

    <!-- Right: List of credentials -->
    <div class="md:col-span-2 space-y-12">
      {education.map((edu) => (
        <div class="space-y-4 relative pl-6 before:absolute before:left-0 before:top-1.5 before:w-1.5 before:h-1.5 before:rounded-full before:bg-accent">
          <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-1 border-b border-rule pb-2">
            <div>
              <h3 class="font-display font-medium text-ink text-base">
                {edu.data.degree}
              </h3>
              <span class="font-mono text-xs text-muted">
                {edu.data.school}
              </span>
            </div>
            <span class="font-mono text-xs text-muted bg-paper-hover border border-rule px-2 py-0.5 rounded-sm">
              {edu.data.dateRange}
            </span>
          </div>
          
          <ul class="space-y-2 text-xs text-muted leading-relaxed font-body list-disc pl-4">
            {(edu.data.achievements || []).map((achievement) => (
              <li>{achievement}</li>
            ))}
          </ul>
        </div>
      ))}

      {education.length === 0 && (
        <div class="text-xs text-muted font-mono">
          no credentials documented. add educational achievements via admin dashboard.
        </div>
      )}
    </div>
  </div>
</section>
