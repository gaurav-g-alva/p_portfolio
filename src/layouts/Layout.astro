---
import '../styles/global.css';
import { siteConfig } from '../config';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = siteConfig.title, 
  description = siteConfig.description 
} = Astro.props;

const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>{title ? `${siteConfig.name} | ${title}` : siteConfig.name}</title>
    <meta name="description" content={description} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- Netlify Identity (Required for Decap CMS production admin panel access) -->
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body class="flex flex-col min-h-screen bg-paper text-ink selection:bg-accent/20 selection:text-ink">
    
    <!-- Navigation Archetype: N1a (Wordmark + Links) with custom design accents -->
    <header class="w-full border-b border-rule bg-paper/80 backdrop-blur-md sticky top-0 z-50">
      <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between relative">
        <a href={import.meta.env.BASE_URL} class="font-display font-medium text-lg tracking-tight hover:text-accent transition-colors z-50">
          {siteConfig.name}
        </a>

        <input type="checkbox" id="nav-toggle" class="peer hidden" />

        <!-- Hamburger Icon (Mobile Only) -->
        <label for="nav-toggle" class="flex md:hidden flex-col gap-1.5 cursor-pointer z-50 p-2" aria-label="Toggle menu">
          <span class="w-6 h-0.5 bg-ink transition-transform duration-300 origin-center" id="bar1"></span>
          <span class="w-6 h-0.5 bg-ink transition-opacity duration-300" id="bar2"></span>
          <span class="w-6 h-0.5 bg-ink transition-transform duration-300 origin-center" id="bar3"></span>
        </label>

        <!-- Navigation Drawer (collapses on mobile, shows horizontal links on desktop) -->
        <nav class="
          fixed inset-0 bg-paper/98 flex flex-col items-center justify-center gap-8 z-40 
          pointer-events-none opacity-0 translate-y-[-10px] transition-all duration-300
          peer-checked:pointer-events-auto peer-checked:opacity-100 peer-checked:translate-y-0
          md:static md:flex-row md:bg-transparent md:inset-auto md:pointer-events-auto md:opacity-100 md:translate-y-0 md:z-auto
          font-mono text-base md:text-xs uppercase tracking-wider
        ">
          <a href={`${import.meta.env.BASE_URL}#projects`} class="hover:text-accent transition-colors nav-link">projects</a>
          <a href={`${import.meta.env.BASE_URL}blog/`} class="hover:text-accent transition-colors nav-link">blog</a>
          {siteConfig.resume && (
            <a href={siteConfig.resume.startsWith('/') ? `${import.meta.env.BASE_URL.replace(/\/$/, '')}${siteConfig.resume}` : siteConfig.resume} target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors nav-link">resume</a>
          )}
          <a href={`mailto:${siteConfig.socials.email}`} class="btn py-1.5 px-4 md:px-3 text-sm md:text-[11px] h-auto min-h-0 border-rule hover:border-accent nav-link">
            contact
          </a>
        </nav>
      </div>
    </header>

    <!-- Main Content Container -->
    <main class="flex-grow max-w-5xl w-full mx-auto px-6 py-12">
      <slot />
    </main>

    <!-- Footer Archetype: Ft6 Letter Close -->
    <footer class="w-full border-t border-rule bg-paper-hover py-12 mt-auto">
      <div class="max-w-5xl mx-auto px-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
        <div class="font-display text-sm text-muted">
          <span class="font-mono text-xs block mb-1 uppercase tracking-wider">close</span>
          yours, {siteConfig.name}. {currentYear}.
        </div>
        <div class="flex gap-4 font-mono text-xs uppercase tracking-wider text-muted">
          {siteConfig.socials.github && (
            <a href={siteConfig.socials.github} target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">github</a>
          )}
          {siteConfig.socials.linkedin && (
            <a href={siteConfig.socials.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">linkedin</a>
          )}
          {siteConfig.socials.twitter && (
            <a href={siteConfig.socials.twitter} target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">twitter</a>
          )}
        </div>
      </div>
    </footer>

    <!-- Netlify Identity Redirect Script -->
    <script define:vars={{ baseUrl: import.meta.env.BASE_URL }}>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", user => {
          if (!user) {
            window.netlifyIdentity.on("login", () => {
              document.location.href = baseUrl + "admin/";
            });
          }
        });
      }
    </script>

    <!-- Mobile Navigation Drawer Controller -->
    <script>
      const navToggle = document.getElementById('nav-toggle') as HTMLInputElement;
      const navLinks = document.querySelectorAll('.nav-link');
      
      navLinks.forEach(link => {
        link.addEventListener('click', () => {
          if (navToggle) navToggle.checked = false;
        });
      });
    </script>

    <!-- Scroll Reveal Controller -->
    <script>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-in');
            observer.unobserve(entry.target);
          }
        });
      }, {
        threshold: 0.05,
        rootMargin: '0px 0px -40px 0px'
      });

      document.querySelectorAll('.reveal').forEach(el => {
        observer.observe(el);
      });
    </script>

    <style>
      #nav-toggle:checked ~ label #bar1 {
        transform: translateY(7px) rotate(45deg);
      }
      #nav-toggle:checked ~ label #bar2 {
        opacity: 0;
      }
      #nav-toggle:checked ~ label #bar3 {
        transform: translateY(-7px) rotate(-45deg);
      }
    </style>
  </body>
</html>
